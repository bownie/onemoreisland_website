---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import Socials from "@/components/Socials.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header titleOverride="One More Island" />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-10 pb-12 sm:pt-12 sm:pb-16 space-y-10">
      
      <div class="app-prose mx-auto max-w-prose space-y-6 text-base leading-8 text-foreground/90 text-justify">
        <h1 class="text-2xl sm:text-xl font-semibold text-foreground/90">Coming soon from Richard W. Bown</h1>
      </div>

      <img src="/one-more-island-book-min.jpg"
           alt="One More Island book cover"
           class="mx-auto block w-1/3 max-w-xs rounded-lg shadow-lg"
      />

      <div class="mx-auto max-w-prose space-y-6 text-base leading-8 text-foreground/90 text-justify">
        <p> 
        Peter Watchett is adrift in Sandport. A man frozen by the sudden awareness of his own
        mortality, carrying secrets he’s never told himself and a past that still haunts him.
        </p>
        <p>
        Seeking refuge on the Kent coast, Peter has withdrawn from the life he once knew to
        live a forgotten dream. But peace proves elusive. As old relationships resurface,
        he is forced to confront the stories his family told, the lies he has lived by, and the
        questions he has spent a lifetime avoiding.
        </p>
        <p>
        As Peter reconnects with those around him, he discovers that rebuilding a life isn't
        about changing the past - it's about finding the courage to live with it.
        </p>    
        <p>
        Set between the relentless pace of London and the quiet coastline of Kent, <b>One More Island</b>
        is a moving novel about family, identity, regret and the fragile hope of second chances.
        </p>
        <p>
        <b>One More Island</b> is the new novel from Richard W. Bown.
        </p>
        
        <p>
          <i>Coming early 2027.</i>
        </p>

        <p>
          Sign up below to get book news, writing updates, and launch information straight to your inbox.
        </p>
      </div>

      <section id="newsletter" class="mt-12 sm:mt-16">
        <NewsletterSignup title="Sign up for updates" description="Get book news, writing updates, and launch information straight to your inbox." />
      </section>
    </section>
    </main>
    <Footer />
  </Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
